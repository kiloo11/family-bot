# Токен бота, полученный у @BotFather
BOT_TOKEN=123456:AA...

# ID семейной группы в Telegram (можно узнать через @userinfobot,
# добавив бота в группу и написав /start в группе).
# Если бот работает 1-на-1 в личке с каждым членом семьи — оставь пустым,
# тогда напоминания будут слаться каждому лично.
FAMILY_CHAT_ID=

# Часовой пояс для расчёта времени напоминаний
TIMEZONE=Europe/Amsterdam

# За сколько дней до срока оплаты слать напоминание
REMINDER_DAYS_BEFORE=3

# Во сколько (час, 0-23) слать ежедневную проверку напоминаний
REMINDER_HOUR=9

# ---------- сайт ----------

# Секрет для подписи сессионных cookie сайта. Сгенерировать:
# python3 -c "import secrets; print(secrets.token_hex(32))"
WEB_SECRET_KEY=

# Порт, на котором сайт слушает на VPS (проксируется через nginx/caddy на 443)
WEB_PORT=8000

# Необязательно: если хочешь пускать на сайт только конкретных людей — впиши их
# telegram user id через запятую (узнать свой ID можно у @userinfobot).
# Если оставить пустым — войти сможет любой, кто нажмёт кнопку Telegram-логина
# (это ок, если ссылка на сайт известна только семье).
ALLOWED_TG_IDS=

# ---------- Telegram Login (OIDC) ----------
# Актуальная (2026) схема входа через Telegram. Взять в @BotFather:
# выбери бота -> Bot Settings -> Web Login.

# Client Secret из BotFather (Client ID брать не нужно — он совпадает с числовой
# частью BOT_TOKEN до двоеточия и подставляется автоматически).
TELEGRAM_CLIENT_SECRET=

# Должен ТОЧНО совпадать с одним из Redirect URI, добавленных в BotFather
# (включая слэш на конце, если он там есть) — например https://fam.xkilo.shop/
TELEGRAM_REDIRECT_URI=
